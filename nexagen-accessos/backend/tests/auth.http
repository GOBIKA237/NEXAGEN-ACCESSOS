@baseUrl = http://localhost:5000/api/auth

### Register
POST {{baseUrl}}/register
Content-Type: application/json

{
  "name": "Test User",
  "email": "test@example.com",
  "password": "test1234"
}

### Login
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "test1234"
}

### Me (paste token from login response above)
GET {{baseUrl}}/me
Authorization: Bearer PASTE_TOKEN_HERE
